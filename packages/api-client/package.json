    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@consulting/contracts": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@consulting/eslint-config": "workspace:*",
    "@consulting/tsconfig": "workspace:*",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
