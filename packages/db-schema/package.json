{
  "name": "@consulting/db-schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "drizzle:generate": "drizzle-kit generate",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@consulting/shared": "workspace:*",
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@consulting/eslint-config": "workspace:*",
    "@consulting/tsconfig": "workspace:*",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "pg": "^8.13.1",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
