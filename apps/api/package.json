{
  "name": "@consulting/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src scripts",
    "test": "vitest run",
    "test:graphrag": "python3 scripts/graphrag_eval_gate.py --rerank --top-k 2 --output ../../artifacts/graphrag-eval-baseline-rerank.json",
    "test:nli": "tsx scripts/nli_verifier_bench.ts",
    "test:hallucination": "tsx scripts/hallucination_reduction_eval.ts",
    "test:quality": "pnpm run test:nli && pnpm run test:hallucination && pnpm run test:graphrag",
    "report:provisioning": "tsx scripts/project_provisioning_report.ts",
    "audit:telegram-topics": "python3 scripts/telegram_topic_audit.py",
    "preview:telegram-topic-backfill": "tsx scripts/sync_telegram_topics_to_web.ts --dry-run",
    "preview:test-backfill": "tsx scripts/test_backfill_preview.ts",
    "backfill:test": "tsx scripts/test_backfill_commit.ts",
    "test:ralph": "python3 scripts/ralph_graphrag_hardening.py --iterations 3 --output ../../artifacts/ralph-graphrag-hardening.json",
    "test:p6-entry": "python3 scripts/p6_precision_trace_loop.py --repeat 3 --output-dir ../../artifacts/p6-entry/latest",
    "test:p6-product-baseline": "python3 scripts/p6_precision_trace_loop.py --repeat 3 --required-repeats 3 --raw-weights 0.20 --rerank-prunes 4 --top-ks 1 --ledger required --output-dir ../../artifacts/p6-product-baseline/latest",
    "test:p6-splade-lite": "python3 scripts/p6_splade_candidate_probe.py --no-fake-embeddings --rerank --top-k 1 --rerank-prune 4 --raw-weight 0.20 --output ../../artifacts/p6-splade-lite/latest/comparison.json",
    "test:p6-raptor-lite": "python3 scripts/p6_raptor_candidate_probe.py --no-fake-embeddings --rerank --top-k 3 --rerank-prune 8 --raw-weight 0.20 --output ../../artifacts/p6-raptor-lite/latest/comparison.json",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@consulting/contracts": "workspace:*",
    "@consulting/db-schema": "workspace:*",
    "@consulting/shared": "workspace:*",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "bullmq": "^5.79.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.22.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@consulting/eslint-config": "workspace:*",
    "@consulting/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "eslint": "^10.6.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  }
}
