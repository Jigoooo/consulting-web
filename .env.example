# Copy to .env.local and fill real values. .env.local is gitignored.
# NEVER commit real secrets.

APP_ENV=local
APP_PUBLIC_URL=http://localhost:5173

# Dedicated Postgres (port 5434) — see docker-compose.local.yml
CONSULTING_POSTGRES_PASSWORD=change_me_local_only
DATABASE_URL=postgres://consulting_app:change_me_local_only@127.0.0.1:5434/consulting

# Dedicated Redis (port 6380; 6379 is Honcho)
REDIS_URL=redis://127.0.0.1:6380

# App auth secrets (generate strong random values)
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Hermes api_server — backend-only, never exposed to browser (ADR-0007)
HERMES_API_BASE_URL=http://127.0.0.1:8000
HERMES_API_KEY=change_me_hermes_key
# P5 runtime governance: API refuses to start a Hermes run if the live API server
# exposes enabled toolsets outside this comma-separated allowlist. MCP/toolsets
# are denied unless explicitly listed here.
# HERMES_TOOL_POLICY_ENFORCED=true
# HERMES_ALLOWED_TOOLSETS=web,search,terminal,file,browser,vision,image_gen,skills,memory,session_search,cronjob,code_execution,delegation,todo,safe

# Artifact red-team is off by default. shadow/warning require a dedicated Hermes
# api_server profile whose GET /v1/toolsets reports zero enabled toolsets and
# whose platform tool config includes no_mcp with an empty resolved tool set.
ARTIFACT_RED_TEAM_MODE=off
# ARTIFACT_RED_TEAM_API_BASE_URL=http://127.0.0.1:8643
# ARTIFACT_RED_TEAM_API_KEY=change_me_dedicated_reviewer_key
